{
  "name": "bolt-react-store",
  "version": "0.1.0",
  "description": "Path-indexed external store for React.",
  "type": "module",
  "packageManager": "bun@1.3.9",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "license": "MIT",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "predev": "bun run build:lib",
    "build": "bun run build:lib && bun run build:app",
    "build:app": "tsc -b && vite build",
    "build:lib": "vite build --config vite.lib.config.ts && tsc -p tsconfig.lib.json",
    "prepack": "bun run build:lib",
    "prepublishOnly": "bun run build:lib",
    "preview": "vite preview --host 0.0.0.0 --outDir dist-playground"
  },
  "dependencies": {
    "lodash": "^4.18.1",
    "mutative": "^1.3.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/lodash": "^4.17.24",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "zustand": "^5.0.14"
  }
}
