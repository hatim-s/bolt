{
  "name": "@hatimcodes/bolt",
  "version": "0.1.0",
  "description": "Tiny, fast path-indexed state management for React — subscribe to paths, not selectors. ~4.3kB, zero boilerplate, TypeScript-first.",
  "keywords": [
    "react",
    "state-management",
    "typescript",
    "frontend"
  ],
  "homepage": "https://github.com/hatim-s/bolt#readme",
  "bugs": {
    "url": "https://github.com/hatim-s/bolt/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hatim-s/bolt.git"
  },
  "author": "hatim-s",
  "type": "module",
  "packageManager": "bun@1.3.9",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "predev": "bun run build:lib",
    "build": "bun run build:lib && bun run build:app",
    "build:app": "tsc -b && vite build",
    "build:lib": "vite build --config vite.lib.config.ts && tsc -p tsconfig.lib.json",
    "prepack": "bun run build:lib",
    "prepublishOnly": "bun run build:lib",
    "preview": "vite preview --host 0.0.0.0 --outDir dist-playground"
  },
  "dependencies": {
    "lodash": "^4.18.1"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@legendapp/state": "^2.1.15",
    "@tailwindcss/vite": "^4.3.0",
    "@types/lodash": "^4.17.24",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "zustand": "^5.0.14"
  }
}
